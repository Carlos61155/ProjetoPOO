<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="AdicionarPersonalController">

    <children>

        <VBox layoutX="200" layoutY="80" spacing="10">

            <Label text="Cadastro de Personal" />

            <TextField fx:id="txtNome" promptText="Nome" />
            <TextField fx:id="txtCpf" promptText="CPF" />
            <TextField fx:id="txtTelefone" promptText="Telefone" />

            <ComboBox fx:id="comboSexo" promptText="Sexo" />
            <ComboBox fx:id="comboEspecialidade" promptText="Especialidade" />

        </VBox>

         <Button layoutX="198.0" layoutY="296.0" onAction="#salvar" text="Salvar" />
         <Button layoutX="302.0" layoutY="296.0" onAction="#voltar" text="Voltar" />
    </children>
</AnchorPane>
