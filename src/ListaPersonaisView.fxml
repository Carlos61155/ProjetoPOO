<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ListaPersonaisController">

    <children>

        <TableView fx:id="tabelaPersonal" layoutX="47.0" layoutY="60.0" prefHeight="220.0" prefWidth="505.0">

            <columns>
                <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                <TableColumn fx:id="colNome" prefWidth="120" text="Nome" />
                <TableColumn fx:id="colCpf" prefWidth="120" text="CPF" />
                <TableColumn fx:id="colTelefone" prefWidth="100" text="Telefone" />
                <TableColumn fx:id="colEspecialidade" prefWidth="120" text="Especialidade" />
            </columns>

        </TableView>

        <Button layoutX="228.0" layoutY="310.0" onAction="#editarPersonal" text="Editar" />

        <Button layoutX="321.0" layoutY="310.0" onAction="#voltar" text="Voltar" />

    </children>
</AnchorPane>
