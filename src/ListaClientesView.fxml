<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ListaClientesController">
   <children>
       <TableView fx:id="tabelaClientes" layoutX="71.0" layoutY="100.0" prefHeight="200" prefWidth="458.0">
           <columns>
               <TableColumn fx:id="colId" text="ID" />
               <TableColumn fx:id="colNome" text="Nome" />
               <TableColumn fx:id="colCpf" prefWidth="120.0" text="CPF" />
               <TableColumn fx:id="colTelefone" text="Telefone" />
           </columns>
       </TableView>
      <Button layoutX="219.0" layoutY="319.0" mnemonicParsing="false" onAction="#editarCliente" text="Editar" />
      <Button fx:id="btnVoltar" layoutX="325.0" layoutY="319.0" mnemonicParsing="false" onAction="#voltar" text="Voltar" />
   </children>
</AnchorPane>
