<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ListaMensalidadesController">

    <children>

        <TableView fx:id="tabelaMensalidades" layoutX="60" layoutY="60" prefHeight="240" prefWidth="480">

            <columns>
                <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                <TableColumn fx:id="colMes" prefWidth="60" text="Mês" />
                <TableColumn fx:id="colStatus" prefWidth="100" text="Status" />
                <TableColumn fx:id="colValor" prefWidth="80" text="Valor" />
                <TableColumn fx:id="colModalidade" prefWidth="100" text="Modalidade" />
                <TableColumn fx:id="colDataPg" prefWidth="120" text="Data Pg." />
            </columns>

        </TableView>

        <Button fx:id="btnVoltar" layoutX="318.0" layoutY="320.0" onAction="#voltar" text="Voltar" />
      <Button layoutX="220.0" layoutY="320.0" mnemonicParsing="false" onAction="#editarMensalidade" text="Editar" />

    </children>
</AnchorPane>
