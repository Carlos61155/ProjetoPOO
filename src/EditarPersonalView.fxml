<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400" prefWidth="600"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="EditarPersonalController">

    <children>

        <VBox layoutX="200" layoutY="80" spacing="10">

            <TextField fx:id="txtNome" promptText="Nome"/>
            <TextField fx:id="txtCpf" promptText="CPF"/>
            <TextField fx:id="txtTelefone" promptText="Telefone"/>

            <ComboBox fx:id="comboSexo" promptText="Sexo"/>
            <ComboBox fx:id="comboEspecialidade" promptText="Especialidade"/>

            <Button text="Salvar" onAction="#salvar"/>
        </VBox>

    </children>
</AnchorPane>