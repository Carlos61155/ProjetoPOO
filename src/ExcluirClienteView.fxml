<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="325.0" prefWidth="499.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ExcluirClienteController">

    <children>
        <Text layoutX="156.0" layoutY="125.0" text="Informe o ID do cliente para excluir:" />

        <TextField fx:id="txtId" layoutX="190.0" layoutY="150.0" prefWidth="120" />

        <Button layoutX="155.0" layoutY="224.0" onAction="#excluir" text="Excluir" />

        <Button layoutX="219.0" layoutY="224.0" onAction="#cancelar" text="Cancelar" />
      <Button fx:id="btnVoltar" layoutX="294.0" layoutY="224.0" mnemonicParsing="false" onAction="#voltar" text="Voltar" />
    </children>
</AnchorPane>
