<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ClienteController">
   <children>
      <VBox layoutX="249.0" layoutY="132.0" prefHeight="139.0" prefWidth="100.0">
         <children>
            <TextField fx:id="txtNome" promptText="Nome" />
            <TextField fx:id="txtCpf" promptText="CPF" />
            <TextField fx:id="txtTelefone" promptText="Telefone" />
            <ComboBox fx:id="comboSexo" prefWidth="150.0" promptText="Sexo" />
         </children>
      </VBox>
      <Button fx:id="salvar" layoutX="201.0" layoutY="271.0" mnemonicParsing="false" onAction="#salvar" text="Salvar" />
      <VBox layoutX="238.0" layoutY="81.0" prefHeight="48.0" prefWidth="122.0">
         <children>
            <ComboBox fx:id="diasTreino" prefWidth="150.0" promptText="Dias de Treino" />
            <ComboBox fx:id="comboModalidade" prefWidth="150.0" promptText="Modalidade" />
         </children>
      </VBox>
      <Button fx:id="cancelar" layoutX="269.0" layoutY="271.0" mnemonicParsing="false" onAction="#cancelar" text="Cancelar" />
      <Button fx:id="btnVoltar" layoutX="349.0" layoutY="271.0" mnemonicParsing="false" onAction="#voltar" text="Voltar" />
   </children>
</AnchorPane>
