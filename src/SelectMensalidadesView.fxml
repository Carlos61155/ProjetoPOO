<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SelectMensalidadesController">

    <children>

        <TableView fx:id="tabelaMensalidades"
                   layoutX="60"
                   layoutY="60"
                   prefHeight="240"
                   prefWidth="480">

            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colMes" text="Mês" prefWidth="60"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                <TableColumn fx:id="colValor" text="Valor" prefWidth="80"/>
                <TableColumn fx:id="colModalidade" text="Modalidade" prefWidth="100"/>
                <TableColumn fx:id="colDataPg" text="Data Pg." prefWidth="120"/>
            </columns>

        </TableView>

        <Button fx:id="btnVoltar"
                layoutX="260.0"
                layoutY="320.0"
                text="Voltar"
                onAction="#voltar"/>

    </children>
</AnchorPane>